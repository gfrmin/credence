; ============================================================
; agent.bdsl — DSL agent for email preference inference
;
; The agent receives a flat MixtureMeasure (belief over programs),
; kernels (compiled by the host), and user feedback observations.
; It does inference. The host manages grammars, programs, sensors,
; and the email domain.
; ============================================================

; ── Core inference: condition belief on observation ──
(define update-belief
  (lambda (belief kernel observation)
    (condition belief kernel observation)))

; ── Sequential conditioning over a list of observations ──
(define update-belief-seq
  (lambda (belief kernel observations)
    (fold-init
      (lambda (b obs) (condition b kernel obs))
      belief
      observations)))

; ── Expected utility for a given action ──
; The host provides an eval function that extracts the relevant
; approval probability for a specific action from each program
(define eu-action
  (lambda (belief action-eval-fn)
    (expect belief (lambda (h) (action-eval-fn h)))))

; ── Agent decision: act or ask ──
; Returns (action-type, value) where:
;   :ask_user if VOI exceeds best domain action EU
;   domain-action otherwise
(define agent-step
  (lambda (belief best-domain-eu voi-ask ask-cost)
    (let ask-eu (- voi-ask ask-cost)
      (if (>= ask-eu best-domain-eu)
        (list :ask_user ask-eu)
        (list :act best-domain-eu)))))
