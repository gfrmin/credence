; ============================================================
; program_agent.bdsl — DSL agent for program-space inference
;
; The agent receives a flat MixtureMeasure (belief over programs),
; kernels (compiled by the host, closing over temporal state),
; and observations (energy deltas). It does inference.
;
; The host manages grammars, programs, sensors, and the world.
; The agent knows nothing about these — it receives a belief
; and computes posteriors and decisions.
; ============================================================

; ── Core inference: condition belief on observation ──
(define update-belief
  (lambda (belief kernel observation)
    (condition belief kernel observation)))

; ── Sequential conditioning over a list of observations ──
(define update-belief-seq
  (lambda (belief kernel observations)
    (fold-init
      (lambda (b obs) (condition b kernel obs))
      belief
      observations)))

; ── Expected value of interacting ──
; Given belief over programs and a preference function,
; compute the expected utility of the interact action
(define eu-interact
  (lambda (belief pref)
    (expect belief (lambda (h) (pref h)))))

; ── Agent decision: submit, abstain, or observe ──
; Returns (action-type, action-value) where:
;   0 = interact (expected positive)
;   1 = observe (gather more info)
;   2 = move toward nearest entity
;   3 = wait
(define agent-step
  (lambda (belief eu-interact-val voi-observe-val move-eu)
    (let best-eu (max eu-interact-val move-eu)
      (if (> voi-observe-val best-eu)
        (list 1 0.0)
        (if (> eu-interact-val move-eu)
          (list 0 eu-interact-val)
          (list 2 move-eu))))))

; ── Prediction: expected probability of enemy ──
; The host passes a function that evaluates the current observation
; against each program's Beta
(define predict-enemy
  (lambda (belief eval-fn)
    (expect belief eval-fn)))
