# credence-proxy configuration for OpenClaw.
# Copy to `.env` and fill in at least one of the two LLM keys below.

# ── LLM providers (need at least one) ─────────────────────────────
# Anthropic key — unlocks Claude Haiku / Sonnet / Opus and the quality judge.
ANTHROPIC_API_KEY=

# OpenAI key — unlocks GPT-4o and GPT-4o-mini.
OPENAI_API_KEY=

# ── Search backends (all optional; DuckDuckGo is always available) ─
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=

# ── Tuning knobs ──────────────────────────────────────────────────
# Expected-utility weights. See docs/adoption/tuning.md for presets.
# EU = CREDENCE_REWARD * P(quality) − CREDENCE_LATENCY_WEIGHT * latency − cost
CREDENCE_REWARD=1.0
CREDENCE_LATENCY_WEIGHT=0.01
